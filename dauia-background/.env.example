# ═══════════════════════════════════════════════════
# DAU'IA — Variables d'environnement
# ═══════════════════════════════════════════════════
# Copiez ce fichier vers .env et remplissez les valeurs.
#   cp .env.example .env

# ── Application ──
APP_ENV=development
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Base de données ──
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dauia
DB_USER=root
DB_PASS=

# ── Sécurité ──
# Générez avec : php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=CHANGEZ_MOI_64_CARACTERES_MINIMUM_EN_PRODUCTION

# ── Email SMTP (pour vérification) ──
SMTP_HOST=smtp.dauphine.psl.eu
SMTP_PORT=587
SMTP_USER=noreply@dauphine.psl.eu
SMTP_PASS=
SMTP_FROM_NAME=DAU'IA
SMTP_FROM_EMAIL=noreply@dauphine.psl.eu

# ── Rate Limiting ──
# Nombre max de tentatives par fenêtre de 15 minutes
RATE_LIMIT_REGISTER=5
RATE_LIMIT_LOGIN=10
RATE_LIMIT_VERIFY=10
RATE_LIMIT_RESET=5
